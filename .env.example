APP_NAME="My Cognito App"
APP_ENV=local
APP_KEY=base64:z/03rijRCPrCZab7N5mclEc8IZjJ9qzEE050AUz1j4w=
APP_DEBUG=true
APP_URL=http://localhost


# COGNITO_HOST example (Cognito Domain) https://us-east-1rtmfsqgpv.auth.us-east-1.amazoncognito.com
# Cambiar aquí abajo por vuestro dominio de Cognito User Pool (grupo de usuarios que esteis usando)
COGNITO_HOST=https://us-east-1rtmfsqgpv.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# Usamos Xampp
COGNITO_CALLBACK_URL=http://localhost/my-cognito-app-php/public/oauth2/callback
COGNITO_SIGN_OUT_URL=http://localhost/my-cognito-app-php/public/logout
COGNITO_LOGIN_SCOPE="openid,profile,email"

# Probamos atributos cookies
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel-cognito
DB_USERNAME=root
DB_PASSWORD=tu_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
